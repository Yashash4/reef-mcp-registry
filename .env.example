# Reef — Environment variables
# Copy this file to .env and fill in values. .env is gitignored.

# --- Gemini ---
# Get an API key at https://aistudio.google.com/
# Model IDs MUST be GA-stable, NOT *-exp / *-preview variants. CISO HARD VETO:
# NYDFS Part 500 + OCC SR-21-14 model-risk-management programmes do not accept
# "experimental" model identifiers in a production risk model. The Reef RIA's
# page-6 model_attestation block records whichever model ID is set here, so
# this default must be a GA identifier the auditor can look up on Google's
# release notes. Override per-deployment via .env (gitignored).
GEMINI_API_KEY=
GEMINI_PRO_MODEL=gemini-2.5-pro
GEMINI_FLASH_MODEL=gemini-2.5-flash

# --- Reef DAST-A Gemini surfaces (A-9) ---
# Set to true/1 to launch headed Chromium for the demo capture path of
# the Gemini-Pro red-team driver. Default is headless for CI.
REEF_PLAYWRIGHT_HEADED=false
# Default number of red-team rounds per Gemini-Pro-driven session.
REEF_GEMINI_RED_MAX_ROUNDS=5

# --- Reef Quote / underwriter agent (A-9 + A-10) ---
# Default coverage amount the underwriter agent sizes the estimated
# premium band against. Mosaic + Munich Re's announced partnership cap
# is $15M (Feb 27 2026); 5M default keeps quotes in SMB band.
REEF_UNDERWRITER_COVERAGE_AMOUNT_USD=5000000
# Override the rubric markdown the underwriter agent loads into its system
# prompt. Defaults to the in-package copy at quote/app/rubrics/.
REEF_UNDERWRITER_RUBRIC=

# --- Reef fleet identity ---
# Position in the TerraFabric hierarchy: fleet → region → site → node.
# Used by the gRPC policy bus client (A-7) on Subscribe.
REEF_FLEET_ID=prod-fleet
REEF_REGION_ID=us-east
REEF_SITE_ID=site-01
REEF_NODE_ID=node-01-01
# Optional cross-check against the A-6 SVID verifier.
REEF_SVID_SUBJECT=

# --- Reef Policy Bus (A-7) ---
# gRPC endpoint of the policy bus. The Lobster Trap node opens a long-
# lived Subscribe stream here and hot-reloads on each verified bundle.
REEF_POLICY_BUS_GRPC_URL=localhost:50051
# Pre-shared secret the admin REST + gRPC Publish requires. The bus
# generates a random token on first boot and writes it to
# <data_dir>/admin_token.txt — copy that into your operator env.
REEF_POLICY_BUS_ADMIN_TOKEN=
# Directory holding ed25519 public keys of trusted bundle publishers.
# Each *.pub / *.pem / *.hex file becomes a trusted publisher; the filename
# stem (e.g. "publisher-prod.pub" → "publisher-prod") is the signer_key_id.
REEF_POLICY_BUS_PUBLISHER_KEYS_DIR=./keys/publishers
# Bus persistence + audit log.
REEF_POLICY_BUS_DATA_DIR=./data
REEF_POLICY_BUS_AUDIT_FILE=./data/audit.jsonl
REEF_POLICY_BUS_GRPC_PORT=50051
REEF_POLICY_BUS_ADMIN_PORT=50052
# Set to 1 to disable the bus client entirely (overrides defaults).
REEF_POLICY_BUS_DISABLE=

# --- MCP signature registry (Layer 1, Reef Atlas — A-5 centerpiece) ---
MCP_REGISTRY_URL=http://localhost:8080
# Reef sidecar verifier configuration. The Lobster Trap pre-ingress hook
# reads these on --enable-reef. URL points at the Atlas FastAPI service.
REEF_MCP_REGISTRY_URL=http://localhost:8080
REEF_MCP_REGISTRY_TIMEOUT_MS=1500
# Atlas runtime knobs (set by docker-compose; override locally).
REEF_ATLAS_DATA_DIR=./data
REEF_ATLAS_PUBLISHER_KEYS_DIR=./keys/publishers
REEF_ATLAS_AUDIT_FILE=./data/audit.jsonl
REEF_ATLAS_SEED_ON_BOOT=1
REEF_ATLAS_HOST=0.0.0.0
REEF_ATLAS_PORT=8080

# --- Sigstore / cosign signing key ---
# Generate locally with: cosign generate-key-pair
SIGSTORE_KEY_PATH=./keys/cosign.key

# --- Reef Lobster Trap fork (A-4) ---
# Directory the QUARANTINE action writes JSONL events to. Created on startup
# if missing. Defaults to ./quarantine when unset.
REEF_QUARANTINE_DIR=./quarantine
# Fallback upstream URL used by the REDIRECT action when a matched rule's
# `redirect_target_band` doesn't resolve in policy.network.redirect_targets.
REEF_REDIRECT_TARGET=http://localhost:8765/gemma-stub
# Webhook target for the HUMAN_REVIEW action. Stage UI's approval queue
# (Phase 2) will host the matching receiver. The Lobster Trap policy YAML's
# notifications.human_review_webhook takes precedence over this env var.
REEF_HUMAN_REVIEW_WEBHOOK=http://localhost:8766/approval-queue

# --- Reef SVID JWT identity (A-6) ---
# Directory holding ed25519 public keys that signed valid agent SVIDs. Each
# *.pub / *.pem file becomes a trusted issuer with KeyID = basename.
REEF_SVID_ISSUER_KEYS_DIR=./keys/svid-issuers

# --- Reef Sigstore-cosign policy bundle signing (A-6) ---
# Public key the hot-reload watcher verifies new policy bundles against.
REEF_POLICY_SIGNER_PUB_KEY=./keys/policy-signer.pub
# Operator-side private key used by `lobstertrap policy sign <bundle>`.
REEF_POLICY_SIGNER_PRIV_KEY=./keys/policy-signer.key

# --- Reef Merkle audit log (A-6) ---
# Persistence directory for the JSONL leaf log. Replayed on startup.
REEF_AUDIT_DIR=./audit

# --- Reef OpenTelemetry exporter (A-6) ---
# Exporter kind: otlp-http | stdout | none. Default stdout.
REEF_OTEL_EXPORTER=stdout
# OTLP collector host:port (only used when exporter=otlp-http).
REEF_OTEL_ENDPOINT=localhost:4318

# --- Reef DAST-A (A-8) ---
# Base URL of the victim Copilot-clone DAST-A drives episodes against. When
# unset the live proxy falls back to http://localhost:3001 (matches victim/).
REEF_VICTIM_URL=http://localhost:3001
# Bind host/port for the DAST-A FastAPI service. The docker-compose stack
# pins :8083 so the Stage UI's NEXT_PUBLIC_REEF_DAST_A_URL=:8083 lines up
# without translation; native runs may use the historical :8088 default.
REEF_DAST_A_HOST=0.0.0.0
REEF_DAST_A_PORT=8083
# Pack catalog + audit JSONL + episode logs land here (gitignored).
REEF_DAST_A_DATA_DIR=./reef/control-plane/dast_a/data
# PPO checkpoints land here (gitignored except dast_a_baseline.zip).
REEF_DAST_A_CHECKPOINTS_DIR=./reef/control-plane/dast_a/checkpoints
# When set, episodes go via this Reef-shaped proxy URL (simulated reef_on).
# Leave empty to talk to the victim directly.
REEF_DAST_A_REEF_PROXY_URL=
# If "1", the FastAPI app forces stub-victim mode (in-process simulator)
# regardless of per-request reef_on. Useful for CI / offline pre-training.
REEF_DAST_A_USE_STUB_VICTIM=0
# Skip the boot-time seed of the 4 canonical attack packs by setting to 0.
REEF_DAST_A_SEED_ON_BOOT=1

# --- Reef Quote / RIA generator (Layer 7, A-10) ---
# ed25519 signing key the RIA generator signs the PDF bytes with. When the
# private key is missing, the signer auto-generates one on first boot and
# writes it to this path so subsequent runs reuse it. The public key is
# written alongside at REEF_QUOTE_SIGNER_PUB_KEY so external verifiers
# (Go + Stage UI) can pick it up.
REEF_QUOTE_SIGNER_PRIV_KEY=./keys/quote-signer.key
REEF_QUOTE_SIGNER_PUB_KEY=./keys/quote-signer.pub
# Human-readable signer identity printed on page 1 + page 6 of the RIA.
# Defaults to the priv-key filename stem when unset.
REEF_QUOTE_SIGNER_KEY_ID=
# Directory the generator persists generated RIA PDFs to. Gitignored.
REEF_QUOTE_DATA_DIR=./reef/control-plane/quote/data
# Directory containing the committed sample RIA. Defaults to
# reef/control-plane/quote/samples (relative to the API process cwd).
REEF_QUOTE_SAMPLES_DIR=
# Generate the committed sample RIA on FastAPI boot when missing. Set to
# false in CI / when running the boot helper offline.
REEF_QUOTE_SAMPLE_ON_BOOT=true
# HTTP timeout (seconds) the RIA generator uses when querying Atlas /
# policy bus / DAST-A.
REEF_RIA_HTTP_TIMEOUT_S=3.0
# Override the URL of upstream services the RIA generator queries.
REEF_ATLAS_URL=http://localhost:8080
REEF_POLICY_BUS_ADMIN_URL=http://localhost:50052
REEF_DAST_A_URL=http://localhost:8083
# Path to the Lobster Trap binary the RIA generator shells out to for
# `audit signed-root`. Resolves to $PATH or the dev workspace fallback
# when unset.
REEF_LOBSTERTRAP_BIN=
# Optional ed25519 private key used by `lobstertrap audit signed-root`
# to sign the exported Merkle root. Falls back to REEF_POLICY_SIGNER_PRIV_KEY
# when unset; then unsigned (a non-empty root is still emitted).
REEF_AUDIT_SIGNER_PRIV_KEY=
# FastAPI bind host/port for the Reef Quote service.
REEF_QUOTE_HOST=0.0.0.0
REEF_QUOTE_PORT=8082

# --- Reef Stage UI (Layer 8, A-11) ---
# The Stage UI (Next.js 14.2.30, port 3000) is a client-side dashboard that
# fetches from the upstream services in the browser. Vars are NEXT_PUBLIC_*
# so Next exposes them to the bundle. Copy to reef/stage-ui/.env.local
# (gitignored) when running outside docker-compose.
NEXT_PUBLIC_REEF_ATLAS_URL=http://localhost:8080
NEXT_PUBLIC_REEF_POLICY_BUS_ADMIN_URL=http://localhost:50052
NEXT_PUBLIC_REEF_DAST_A_URL=http://localhost:8083
NEXT_PUBLIC_REEF_QUOTE_URL=http://localhost:8082
NEXT_PUBLIC_REEF_VICTIM_URL=http://localhost:3001
NEXT_PUBLIC_REEF_FLEET_ID=prod-fleet
# Same admin token the policy-bus admin REST emits at first boot — needed
# to render the audit-tail feed on the Public Safety Page. Without it the
# feed shows a "set token" hint and degrades gracefully.
NEXT_PUBLIC_REEF_POLICY_BUS_ADMIN_TOKEN=
