# Reef Stage UI — environment variables
#
# Copy to `.env.local` (gitignored) and adjust the URLs if any service
# isn't on its default port. The Stage UI talks to all 5 services from
# the browser — they must each set permissive CORS for localhost:3000.

NEXT_PUBLIC_REEF_ATLAS_URL=http://localhost:8080
NEXT_PUBLIC_REEF_POLICY_BUS_ADMIN_URL=http://localhost:50052
NEXT_PUBLIC_REEF_DAST_A_URL=http://localhost:8083
NEXT_PUBLIC_REEF_QUOTE_URL=http://localhost:8082
NEXT_PUBLIC_REEF_VICTIM_URL=http://localhost:3001
NEXT_PUBLIC_REEF_FLEET_ID=prod-fleet

# Optional admin token for the policy-bus admin REST. Without it the
# `/audit/tail` endpoint returns 401 — Stage UI degrades to "service
# offline" badge on the audit feed but everything else still works.
NEXT_PUBLIC_REEF_POLICY_BUS_ADMIN_TOKEN=
